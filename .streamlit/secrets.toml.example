# Streamlit Cloud Secrets — copy this content into:
# Streamlit Cloud dashboard → App settings → Secrets
#
# DO NOT rename this file to secrets.toml and commit it.
# secrets.toml is already in .gitignore.

# AI summaries (free key at console.groq.com)
GROQ_API_KEY = "your_groq_api_key_here"

# Newsletter subscribers (Supabase project)
SUPABASE_URL = "https://your-project.supabase.co"
SUPABASE_KEY = "your_supabase_anon_key_here"

# Weekly digest emails (resend.com)
RESEND_API_KEY = "your_resend_api_key_here"
